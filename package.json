{
  "name": "claustodian",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-schema.ts \"data/**/*.json\"",
    "scrape": "tsx scripts/scrape-changelog.ts",
    "diff": "tsx scripts/diff-snapshots.ts",
    "coverage": "tsx scripts/check-coverage.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^5.2.0",
    "smol-toml": "^1.7.0",
    "tinyglobby": "^0.2.17"
  }
}
