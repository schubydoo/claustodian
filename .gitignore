# Local Claude Code settings / agent state
/.claude/

# Working notes, plans, and scratch artifacts (not part of the published repo)
/scratch/

# Dependencies and build output
node_modules/
dist/
coverage/

# JUnit test report (emitted in CI for Codecov Test Analytics)
test-report.junit.xml

# Generated data exports (built in CI from committed JSON, never hand-edited)
data/**/*.yaml
data/**/*.toml
# Cross-version catalog (built at deploy time from data/versions/*.json)
data/catalog.json

# Python bytecode (from running examples/*.py)
__pycache__/
*.pyc
